# Horus.AI local configuration
#
# For the default local setup, fill only your provider API key.

# Defaults to OpenAI. Change this to openrouter or groq if that is your provider.
LLM_PROVIDER=openai
OPENAI_API_KEY=

# Optional: use another supported provider.
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
#
# LLM_PROVIDER=groq
# GROQ_API_KEY=

# Optional model override. Leave unset to use the provider default.
# LLM_MODEL=

# Optional local server ports and storage.
# PORT=3001
# HOST=0.0.0.0
# CORS_ORIGIN=http://127.0.0.1:5173,http://127.0.0.1:8080
# HORUS_DATA_DIR=.horus/data

# Optional local web/preview ports for pnpm dev.
# HORUS_WEB_DEV_HOST=127.0.0.1
# HORUS_WEB_DEV_PORT=5173
# HORUS_API_PROXY_HOST=127.0.0.1
# HORUS_API_PROXY_PORT=3001
# HORUS_WEB_PREVIEW_HOST=127.0.0.1
# HORUS_WEB_PREVIEW_PUBLIC_HOST=127.0.0.1
# HORUS_WEB_PREVIEW_PORT=5174

# Optional Docker host/container ports.
# HORUS_WEB_HOST_PORT=8080
# HORUS_WEB_CONTAINER_PORT=8080
# HORUS_API_HOST_PORT=3001
# HORUS_API_CONTAINER_PORT=3000
# HORUS_GENERATED_PROJECT_PREVIEW_BIND_HOST=0.0.0.0
# HORUS_GENERATED_PROJECT_PREVIEW_PUBLIC_HOST=127.0.0.1
# HORUS_GENERATED_PROJECT_PREVIEW_BASE_PORT=5184
# HORUS_GENERATED_PROJECT_PREVIEW_PORT_RANGE=5184-6184
