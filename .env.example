# Horus.AI local configuration
#
# For the default local setup, fill only your provider API key.

# Defaults to OpenAI. Change this to openrouter or groq if that is your provider.
LLM_PROVIDER=openai
OPENAI_API_KEY=

# Optional: use another supported provider.
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
#
# LLM_PROVIDER=groq
# GROQ_API_KEY=

# Optional model override. Leave unset to use the provider default.
# LLM_MODEL=

# Optional local ports and storage.
# PORT=3001
# HOST=0.0.0.0
# CORS_ORIGIN=http://localhost:5173,http://localhost:8080
# HORUS_DATA_DIR=.horus/data

# Optional production or multi-user settings.
# Keep these unset for local use.
# HORUS_ENV=production
# HORUS_AUTH_MODE=token
# HORUS_API_TOKEN=
# HORUS_TENANT_ID=
# PERSISTENCE_DRIVER=postgres
# DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>
# DATABASE_SSL=false
