# Horus.AI local configuration
#
# For the default local setup, fill only your provider API key.

LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
OPENAI_API_KEY=

# Optional: use another supported provider.
# LLM_PROVIDER=openrouter
# LLM_MODEL=<provider-model>
# OPENROUTER_API_KEY=
#
# LLM_PROVIDER=groq
# LLM_MODEL=<provider-model>
# GROQ_API_KEY=

# Optional local ports and storage.
# PORT=3001
# HOST=0.0.0.0
# CORS_ORIGIN=http://localhost:5173,http://localhost:8080
# HORUS_DATA_DIR=.horus/data

# Optional production or multi-user settings.
# Keep these unset for local use.
# HORUS_ENV=production
# HORUS_AUTH_MODE=token
# HORUS_API_TOKEN=
# HORUS_TENANT_ID=
# PERSISTENCE_DRIVER=postgres
# DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>
# DATABASE_SSL=false
