# Horus.AI LLM provider configuration

# Required global defaults.
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini

# Required key for the selected provider.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Optional base URL overrides.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional per-agent provider/model overrides.
# SPEC_AGENT_PROVIDER=openai
# SPEC_AGENT_MODEL=gpt-5-mini
# FRONT_AGENT_PROVIDER=openai
# FRONT_AGENT_MODEL=gpt-5-mini
# QA_AGENT_PROVIDER=openai
# QA_AGENT_MODEL=gpt-5-mini
# CURATOR_AGENT_PROVIDER=openai
# CURATOR_AGENT_MODEL=gpt-5-mini

# Optional per-agent tuning.
# FRONT_AGENT_TEMPERATURE=0.2
# FRONT_AGENT_MAX_TOKENS=8192
# QA_AGENT_TEMPERATURE=1
# CURATOR_AGENT_TEMPERATURE=1
