# Horus.AI LLM provider configuration

# Required global defaults. Choose both explicitly for the target environment.
LLM_PROVIDER=
LLM_MODEL=

# Required key for the selected provider.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Optional base URL overrides.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional per-agent provider/model overrides.
# SPEC_AGENT_PROVIDER=
# SPEC_AGENT_MODEL=
# FRONT_AGENT_PROVIDER=
# FRONT_AGENT_MODEL=
# QA_AGENT_PROVIDER=
# QA_AGENT_MODEL=
# CURATOR_AGENT_PROVIDER=
# CURATOR_AGENT_MODEL=

# Optional per-agent tuning.
# FRONT_AGENT_TEMPERATURE=0.2
# FRONT_AGENT_MAX_TOKENS=8192
# QA_AGENT_TEMPERATURE=1
# CURATOR_AGENT_TEMPERATURE=1

# Persistence.
# file keeps local JSON stores under HORUS_DATA_DIR; postgres enables the repository layer.
PERSISTENCE_DRIVER=file
# All Horus-managed local file-mode state lives under this directory.
# Relative paths resolve from the repository root, not the process cwd.
HORUS_DATA_DIR=.horus/data
# DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>
# DATABASE_SSL=false

# HTTP server.
# PORT=3001
# HOST=0.0.0.0
# Comma-separated origins. Local development may leave this empty; production must set explicit origins and cannot use "*".
# CORS_ORIGIN=

# Production security boundary.
# Local development is unauthenticated by default. Production requires at least
# HORUS_API_TOKEN or HORUS_API_ADMIN_TOKEN plus HORUS_TENANT_ID.
# HORUS_ENV=production
# HORUS_AUTH_MODE=token
# HORUS_API_TOKEN=
# HORUS_API_ADMIN_TOKEN=
# HORUS_TENANT_ID=

# File persistence is local/dev oriented and not safe for multi-process production
# unless the operator explicitly accepts that risk. Prefer PERSISTENCE_DRIVER=postgres.
# HORUS_ALLOW_FILE_DRIVER_IN_PRODUCTION=false

# Durable outbox processing lease TTL. Defaults to 120000ms.
# HORUS_OUTBOX_PROCESSING_LEASE_TTL_MS=120000

# Optional coding context budget. When unset, chat planning skips packed context
# generation instead of applying hidden token defaults.
# HORUS_CODING_CONTEXT_MAX_TOKENS=
# HORUS_CODING_CONTEXT_RESERVE_TOKENS=
# HORUS_CODING_CONTEXT_MAX_ITEM_TOKENS=

# Optional cache for code context/AST metadata.
# Defaults to memory and is safe for local development without Redis.
# Set HORUS_CACHE_DRIVER=redis plus HORUS_REDIS_URL or REDIS_URL to share cache
# across server processes. Set HORUS_CACHE_DRIVER=off to disable caching.
# HORUS_CACHE_DRIVER=memory
# HORUS_REDIS_URL=redis://localhost:6379
# HORUS_REDIS_KEY_PREFIX=horus

# Frontend preview project seed.
# These values are intentionally environment-driven so the same build runs on
# Windows, macOS, Linux, CI, containers, and different workspace layouts.
# HORUS_WEB_PROJECT_ROOT=apps/web
# HORUS_WEB_PROJECT_NAME=user_stories
# HORUS_WEB_PROJECT_SLUG=user-stories
# HORUS_WEB_DEFAULT_ROUTE=/
# HORUS_PACKAGE_MANAGER=pnpm
# HORUS_WEB_PACKAGE_FILTER=@u-build/web
# HORUS_WEB_PREVIEW_HOST=localhost
# HORUS_WEB_PREVIEW_PORT=5174
# HORUS_WEB_PREVIEW_URL=http://localhost:5174

# Generated project workspace roots. Defaults are derived from HORUS_DATA_DIR.
# HORUS_PROJECT_WORKSPACE_ROOT=.horus/data/project-workspaces
# HORUS_PROJECT_RUN_WORKSPACE_ROOT=.horus/data/project-run-worktrees
