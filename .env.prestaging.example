# Copy to .env.prestaging.local and fill the secrets before running:
# docker compose --env-file .env.prestaging.local up --build

POSTGRES_PASSWORD=change-me-local-postgres-password
HORUS_API_TOKEN=change-me-local-member-token
HORUS_API_ADMIN_TOKEN=change-me-local-admin-token
HORUS_TENANT_ID=local-prestaging

CORS_ORIGIN=http://localhost:8080
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
