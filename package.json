{
  "name": "u-build",
  "version": "0.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "cache:redis-smoke": "node scripts/redis-cache-smoke.mjs",
    "e2e:chat-preview": "node scripts/horus-chat-preview-e2e.mjs",
    "preview:smoke": "node scripts/preview-browser-smoke.mjs",
    "security:secrets": "node scripts/secret-scan.mjs",
    "test": "pnpm verify:ci",
    "type-check": "turbo run type-check",
    "verify:ci": "pnpm lint && pnpm type-check && pnpm security:secrets && pnpm build",
    "verify:production-smoke": "node scripts/production-hardening-smoke.mjs",
    "verify:prestage": "node scripts/prestaging-smoke.mjs",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
