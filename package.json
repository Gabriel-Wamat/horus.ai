{
  "name": "u-build",
  "version": "0.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "cache:redis-smoke": "node scripts/redis-cache-smoke.mjs",
    "e2e:chat-preview": "node scripts/horus-chat-preview-e2e.mjs",
    "preview:smoke": "node scripts/preview-browser-smoke.mjs",
    "benchmark:context": "pnpm --filter @u-build/shared build && pnpm --filter @u-build/server build && node scripts/context-retrieval-benchmark.mjs",
    "security:secrets": "node scripts/secret-scan.mjs",
    "test": "pnpm verify:ci",
    "test:server": "pnpm --filter @u-build/shared build && pnpm --filter @u-build/server build && node --test apps/server/test/*.test.mjs",
    "type-check": "turbo run type-check",
    "verify:ci": "pnpm lint && pnpm type-check && pnpm security:secrets && pnpm build && pnpm test:server && pnpm benchmark:context && pnpm verify:llm-providers",
    "verify:docker": "node scripts/docker-smoke.mjs",
    "verify:llm-providers": "node scripts/llm-provider-smoke.mjs",
    "verify:production-smoke": "node scripts/production-hardening-smoke.mjs",
    "db:seed": "pnpm --filter @u-build/server db:seed",
    "infra:deploy:gcp": "node infra/gcp/deploy-cloud-run.mjs",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
