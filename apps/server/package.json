{
  "name": "@u-build/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/groq": "^1.2.1",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "@langchain/openrouter": "^0.3.0",
    "@u-build/shared": "workspace:*",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "uuid": "^10.0.0",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
