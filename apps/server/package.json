{
  "name": "@u-build/server",
  "version": "0.0.0",
  "private": true,
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "db:migrate": "tsx src/infrastructure/database/migrateCli.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo",
    "eval:curator": "tsx evals/curator.eval.ts",
    "eval:curator:llm": "tsx evals/curator.eval.ts --llm",
    "eval:spec": "tsx evals/spec.eval.ts",
    "eval:spec:llm": "tsx evals/spec.eval.ts --llm",
    "eval:front": "tsx evals/front.eval.ts",
    "eval:front:llm": "tsx evals/front.eval.ts --llm",
    "eval:qa": "tsx evals/qa.eval.ts",
    "eval:qa:llm": "tsx evals/qa.eval.ts --llm",
    "eval:odin": "tsx evals/odin.eval.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/groq": "^1.2.1",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-checkpoint-postgres": "1.0.1",
    "@langchain/openai": "^1.4.7",
    "@langchain/openrouter": "^0.3.0",
    "@u-build/shared": "workspace:*",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "pg": "^8.21.0",
    "redis": "^6.0.0",
    "tree-sitter": "0.21.1",
    "tree-sitter-typescript": "0.23.2",
    "typescript": "^5.7.3",
    "uuid": "^10.0.0",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3"
  }
}
